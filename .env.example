# Copy to .env and fill in your values.

# Binance API (required for announcement WebSocket)
BINANCE_API_KEY=your_api_key
BINANCE_API_SECRET=your_api_secret

# Bark push — API base (not the in-app test URL path).
# Public HTTPS may hit Cloudflare; server-side pushes from Docker should use the internal
# bark container on the same network, e.g. http://bark-server:8080
BARK_SERVER=https://bark.chiloh.com
BARK_KEYS=key1,key2
BARK_DEFAULT_LEVEL=critical
BARK_DEFAULT_SOUND=alarm
BARK_ICON=https://public.bnbstatic.com/20190405/eb2349c3-b2f8-4a93-a286-8f86a62ea9d8.png
BARK_VOLUME=10
BARK_BADGE=1
BARK_CALL=1
BARK_IS_ARCHIVE=1
BARK_MAX_RETRIES=3

# Telegram push
TG_BOT_TOKEN=your_bot_token
TG_CHAT_ID=your_chat_id
TG_DISABLE_PREVIEW=false
TG_DISABLE_NOTIFICATION=false
TG_MAX_RETRIES=3

# Announcement monitor (WebSocket)
ANNOUNCEMENT_CATALOG_IDS=48
ANNOUNCEMENT_KEYWORDS=Contract,Futures,合约,期货
ANNOUNCEMENT_GROUP=币安公告

# Announcement BAPI poll (backup for WebSocket, queries same catalogIds)
ANNOUNCEMENT_POLL_ENABLED=true
ANNOUNCEMENT_POLL_INTERVAL_MS=30000
ANNOUNCEMENT_POLL_PAGE_SIZE=10

# Alpha monitor (official Token List API)
ALPHA_API_POLL_INTERVAL=10
ALPHA_GROUP=Alpha监控

# WebSocket
WS_PING_INTERVAL_MS=25000
WS_RECONNECT_MIN_MS=1000
WS_RECONNECT_MAX_MS=30000

# Store
STORE_TTL_DAYS=30
STORE_FLUSH_DEBOUNCE_MS=500

# Health check
HEALTH_PORT=8080

# Logging
LOG_LEVEL=info

# Data directory
DATA_DIR=./data
